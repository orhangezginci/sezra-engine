# Kopieren nach .env und echte Werte eintragen.
# .env selbst wird NIE committet (siehe .gitignore) - Lehre aus Legacy-SEZRA,
# wo Credentials direkt im docker-compose.yml im Klartext standen.

RABBITMQ_USER=sezra
RABBITMQ_PASSWORD=change-me-locally

POSTGRES_USER=sezra
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=sezra_engine

# Hart verdrahtete Projekt-Kennung fuer den json-adapter-service
# (noch kein dynamisches Projekt-Konzept, siehe project_id im
# Envelope-Schema). Eigene UUID v4 generieren, z. B.:
# python3 -c "import uuid; print(uuid.uuid4())"
SEZRA_PROJECT_ID=8a15bb2d-09f1-4e2d-90f3-5eb21283d8a6

# Anbieter fuer die Textgenerierung in analyzer-service (Embeddings
# bleiben immer lokal ueber Ollama, unabhaengig von dieser Variable).
# "ollama" = lokal, keine Daten verlassen die Maschine - noetig fuer
# produktiven Einsatz mit sensiblen Daten.
# "openai"/"gemini" = Cloud, schneller und aktuell bessere Qualitaet -
# nur fuer Entwicklung/Tests mit unkritischen Daten geeignet.
LLM_PROVIDER=ollama

# Nur noetig, wenn LLM_PROVIDER=openai. Modellname selbst waehlen (z. B.
# gpt-4o-mini) - wird hier bewusst nicht vorgegeben, da sich das
# Modellangebot schneller aendert als dieses Repo.
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=

# Nur noetig, wenn LLM_PROVIDER=gemini.
GEMINI_API_KEY=

GEMINI_GENERATION_MODEL=gemini-2.5-flash
